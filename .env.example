# Telegram Bot Token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgresql://taxibot:your_secure_password@localhost:5432/taxi_bot

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789

# Docker Compose only: PostgreSQL password
DB_PASSWORD=taxibot_dev_password

# Maximum search radius in km (default: 10)
SEARCH_RADIUS_KM=10

# Maximum drivers returned per rider search (default: 10)
MAX_RESULTS=10

# Exclude drivers whose location hasn't updated in N hours (default: 1)
LOCATION_EXPIRY_HOURS=1

# Optional admin panel port (default: 3000)
ADMIN_PORT=3000

# Optional admin panel secret token (default: change_this)
ADMIN_SECRET=change_this
